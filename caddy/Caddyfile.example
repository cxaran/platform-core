# Plantilla del Caddyfile que genera scripts/install.sh (opción TLS automático).
# Caddy obtiene y renueva solo los certificados de Let's Encrypt para el dominio y
# proxya TODO a nginx (que sigue siendo el enrutador interno del stack).
#
# Requisitos: el dominio debe apuntar (registro A/AAAA) a este servidor y los
# puertos 80 y 443 deben estar abiertos en el firewall del VPS.

tu-dominio.com {
	encode gzip
	reverse_proxy nginx:80
}
