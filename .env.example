# PROJECT_NAME es la marca base del despliegue; el nombre VISIBLE en correos y
# textos es institution_name (editable en Configuración del sistema).
PROJECT_NAME=Platform Core
ENVIRONMENT=local
TRUSTED_BROWSER_ORIGINS=http://localhost:3000

# Perfiles de compose de la instalación (el instalador los fija):
#   taskiq = tareas en segundo plano · db = PostgreSQL local en contenedor
# COMPOSE_PROFILES=db,taskiq
# Puerto HTTP del stack; el HTTPS lo pone el túnel/proxy EXTERNO (Cloudflare
# Tunnel en el mismo servidor → bind a loopback; ALB/proxy externo → sin bind):
# HTTP_PORT=127.0.0.1:8088

SECRET_KEY=change-me-use-a-long-random-secret
ALGORITHM=HS256
# DEFAULTS de despliegue: la política real es editable en runtime (system_settings,
# NULL = usar estos valores): sesiones, vigencia de tokens por correo, intentos
# antes de bloquear y zona horaria (APPLICATION_TIMEZONE).
ACCESS_TOKEN_EXPIRE_MINUTES=30
EMAIL_TOKEN_EXPIRE_MINUTES=30
TRYS_BEFORE_LOCK=5
# Zona horaria IANA por defecto de los filtros de calendario (editable en la UI).
APPLICATION_TIMEZONE=UTC

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_DB=platform_core

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=dev@example.com
SMTP_PASSWORD=dev-password
SMTP_FROM_EMAIL=dev@example.com
SMTP_FROM_NAME=Platform Core Dev
SMTP_TLS=false
SMTP_SSL=false
SMTP_USE_CREDENTIALS=false

# Usado por: python -m backend.app.core.bootstrap
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin1234
BOOTSTRAP_ADMIN_NAME=Admin
BOOTSTRAP_ADMIN_LAST_NAME=Platform
BOOTSTRAP_ADMIN_ROLE_NAME=Administrador
BOOTSTRAP_USER_ROLE_NAME=Usuario

# Usado por Bootstrap HTTP de producto (/api/v1/bootstrap/*). Obligatorio en production.
BOOTSTRAP_SETUP_TOKEN=change-me-use-a-long-random-bootstrap-token

# CLAVE MAESTRA ÚNICA de cifrado de secretos de configuración en reposo (Fernet,
# urlsafe base64 de 32 bytes). Obligatoria en producción. Generar:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=
# Clave legada de la cadena de descifrado (despliegues previos); normalmente vacía.
BACKUP_TOKEN_ENCRYPTION_KEY=

# --- Agent Gateway (copiloto agéntico) ---
# Secreto compartido con el que el backend FIRMA el ticket de conexión y el gateway lo
# VERIFICA. Deben coincidir: AGENT_GATEWAY_TICKET_SIGNING_SECRET (backend) ==
# GATEWAY_AGENT_TICKET_SECRET (gateway). Obligatorio para usar el copiloto.
AGENT_GATEWAY_TICKET_SIGNING_SECRET=change-me-use-a-long-random-secret
# TTLs: defaults de despliegue; editables en runtime en Configuración del sistema.
AGENT_GATEWAY_TICKET_TTL_SECONDS=120
# Secreto server-to-server del puente interno de arriendo de credencial. Debe coincidir:
# AGENT_GATEWAY_INTERNAL_SECRET (backend) == GATEWAY_BACKEND_INTERNAL_SECRET (gateway).
AGENT_GATEWAY_INTERNAL_SECRET=change-me-use-a-long-random-internal-secret
AGENT_GATEWAY_LEASE_TTL_SECONDS=300
# Variables del servicio model-gateway (deben reflejar los dos secretos de arriba).
GATEWAY_AGENT_TICKET_SECRET=change-me-use-a-long-random-secret
GATEWAY_BACKEND_INTERNAL_URL=http://backend:8000
GATEWAY_BACKEND_INTERNAL_SECRET=change-me-use-a-long-random-internal-secret
GATEWAY_ALLOWED_ORIGINS=http://localhost:3000
# Proveedores de IA (habilitar los que uses y añadir la credencial por usuario en la UI):
# GATEWAY_OPENAI_ENABLED=true / GATEWAY_ANTHROPIC_ENABLED=true / GATEWAY_GEMINI_ENABLED=true ...
# GATEWAY_FAKE_ENABLED=true  # solo dev/demo: turno sintético sin credencial ni red.

# Gate de DESPLIEGUE del registro público: sin valor, sólo se permite en local. La
# política real (encendido/apagado) vive en system_settings, editable en la UI.
# REGISTRATION_ALLOWED=false

# Respaldos hacia Google Drive. BACKUPS_ENABLED es el kill-switch del tick (el
# interruptor real es backup_settings.enabled, editable en la UI).
BACKUPS_ENABLED=true
BACKUP_EXPLORER_ENABLED=false
BACKUP_TEMP_DIR=/tmp/platform-core-backups
# Defaults de despliegue; editables en runtime en la configuración de respaldos.
BACKUP_RUN_LEASE_MINUTES=120
BACKUP_MAX_ATTEMPTS=3
# OAuth de la app de Google (web application); alternativa: capturarlos en la UI
# (se guardan cifrados). El client secret NUNCA se persiste en claro.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=
